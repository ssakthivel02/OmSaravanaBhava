--- before/assets/js/audio-collections.js
+++ release171/assets/js/audio-collections.js
@@ -0,0 +1 @@
+(()=>{'use strict';const KEY='osb-audio-favourites';document.addEventListener('DOMContentLoaded',async()=>{const root=document.getElementById('audioCollections');if(!root)return;const [c,p]=await Promise.all([fetch('data/audio-collections.json').then(r=>r.json()),fetch('data/read-aloud-playlist.json').then(r=>r.json())]);const byId=new Map(p.map(x=>[x.id,x]));let fav=new Set(JSON.parse(localStorage.getItem(KEY)||'[]'));const render=()=>{root.innerHTML=c.map(g=>`<section class="card"><h2>${g.titleTa}</h2><h3>${g.titleEn}</h3>${g.trackIds.map(id=>{const t=byId.get(id);return t?`<div class="audio-list-row"><span>${t.titleTa}</span><button class="btn secondary" data-fav="${id}" aria-pressed="${fav.has(id)}">${fav.has(id)?'★ Saved':'☆ Save'}</button><a class="btn" href="audio-library.html?track=${id}">Play</a></div>`:''}).join('')}</section>`).join('')};document.addEventListener('click',e=>{const b=e.target.closest('[data-fav]');if(!b)return;const id=b.dataset.fav;fav.has(id)?fav.delete(id):fav.add(id);localStorage.setItem(KEY,JSON.stringify([...fav]));render()});render()})})();--- before/service-worker.js
