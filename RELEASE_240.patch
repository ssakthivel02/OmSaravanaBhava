diff --git a/.github/workflows/release-240-closure.yml b/.github/workflows/release-240-closure.yml
new file mode 100644
index 0000000000000000000000000000000000000000..b4af5bb90e29fd933d3ffd4999b7016100408e44
--- /dev/null
+++ b/.github/workflows/release-240-closure.yml
@@ -0,0 +1,70 @@
+name: Release 240 Self-Healing Closure
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - manifest-release-240.json
+      - data/release-240-closure.json
+      - .github/workflows/release-240-closure.yml
+  workflow_dispatch:
+
+permissions:
+  contents: write
+
+concurrency:
+  group: release-240-self-healing-closure
+  cancel-in-progress: false
+
+jobs:
+  finalize:
+    if: github.actor != 'github-actions[bot]'
+    runs-on: ubuntu-latest
+    timeout-minutes: 25
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+          token: ${{ secrets.GITHUB_TOKEN }}
+      - uses: actions/setup-python@v5
+        with:
+          python-version: '3.12'
+      - uses: actions/setup-node@v4
+        with:
+          node-version: '22'
+      - name: Verify stage ancestry and pending state
+        env:
+          PYTHONDONTWRITEBYTECODE: '1'
+        run: |
+          python -B scripts/release240/verify-stage.py --root .
+          python -B -m tools.release_closure.validate --root . --mode pending
+      - name: Prepare authoritative closure commit
+        env:
+          PYTHONDONTWRITEBYTECODE: '1'
+        run: |
+          python -B scripts/release240/finalize-release-240.py --root . --stage-sha "${{ GITHUB_SHA }}"
+          python -B scripts/release240/verify-final-state.py --root .
+          python -B -m tools.release_closure.validate --root . --mode staged
+      - name: Run complete validation suite
+        env:
+          PYTHONDONTWRITEBYTECODE: '1'
+        run: |
+          python -B scripts/release240/run-release-tests.py --root .
+          python -B -m tools.repository_hygiene.validate --root .
+          python -B -m tools.repository_integrity.validate --root . --manifest manifest-release-240.json
+          python -B tools/release_validate.py --root . --manifest manifest-release-240.json --package-mode
+          python -B scripts/release240/finalize-release-240.py --root . --mark-pass
+      - name: Create exact Release 240 commit
+        run: |
+          git config user.name "OmSaravanaBhava Release Bot"
+          git config user.email "actions@users.noreply.github.com"
+          git diff --cached --name-status
+          git commit -m "Release 240: complete repository cleanup and establish self-healing release closure"
+      - name: Validate final commit
+        env:
+          PYTHONDONTWRITEBYTECODE: '1'
+        run: |
+          python -B tools/release_validate.py --root . --manifest manifest-release-240.json --repository-mode --strict-commit-subject
+          python -B -m tools.release_closure.validate --root . --mode final
+      - name: Push authoritative closure commit
+        run: git push origin HEAD:main
