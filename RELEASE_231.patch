@@ -0,0 +1,84 @@
+name: Release 231 Canonical Publication Status Integrity
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - "content-status.html"
+      - "discovery.html"
+      - "site-directory.html"
+      - "data/content-status.json"
+      - "data/publication-boundaries.json"
+      - "assets/css/route-status-reconciliation.css"
+      - "assets/js/content-status-audit.mjs"
+      - "assets/js/route-status-reconciliation.js"
+      - "service-worker.js"
+      - "tests/route-status-reconciliation.test.mjs"
+      - "tools/release_231_validate.py"
+      - "manifest-release-231.json"
+      - "RELEASE_231_*"
+      - ".github/workflows/release-231-integrity.yml"
+  pull_request:
+    paths:
+      - "content-status.html"
+      - "discovery.html"
+      - "site-directory.html"
+      - "data/content-status.json"
+      - "data/publication-boundaries.json"
+      - "assets/css/route-status-reconciliation.css"
+      - "assets/js/content-status-audit.mjs"
+      - "assets/js/route-status-reconciliation.js"
+      - "service-worker.js"
+      - "tests/route-status-reconciliation.test.mjs"
+      - "tools/release_231_validate.py"
+      - "manifest-release-231.json"
+      - "RELEASE_231_*"
+      - ".github/workflows/release-231-integrity.yml"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-231-status-integrity-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  validate:
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check out repository
+        uses: actions/checkout@v4
+
+      - name: Set up Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Validate JavaScript syntax
+        run: |
+          node --check assets/js/route-status-reconciliation.js
+          node --check assets/js/content-status-audit.mjs
+          node --check service-worker.js
+
+      - name: Run Release 231 tests
+        run: node --test tests/route-status-reconciliation.test.mjs
+
+      - name: Run repository-mode Release 231 validator
+        run: |
+          python tools/release_231_validate.py             --root .             --report artifacts/release-231-repository-validation.json
+
+      - name: Upload validation evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-231-canonical-status-evidence
+          path: artifacts/release-231-repository-validation.json
+          if-no-files-found: warn
+          retention-days: 30
