@@ -0,0 +1,83 @@
+name: Release 231 Production Status Propagation Smoke
+
+on:
+  workflow_dispatch:
+  schedule:
+    - cron: "43 2 * * *"
+  workflow_run:
+    workflows: ["pages-build-deployment"]
+    types: [completed]
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-231-production-status-smoke
+  cancel-in-progress: true
+
+jobs:
+  smoke:
+    if: >-
+      github.event_name != 'workflow_run' ||
+      github.event.workflow_run.conclusion == 'success'
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Verify deployed Release 231 assets and consumers
+        shell: bash
+        run: |
+          python - <<'PY'
+          import json
+          import sys
+          import time
+          import urllib.request
+
+          checks = [
+              ("https://omsaravanabhava.org/content-status.html", 'data-release="231"'),
+              ("https://omsaravanabhava.org/discovery.html", 'data-release="231"'),
+              ("https://omsaravanabhava.org/site-directory.html", 'data-release="231"'),
+              ("https://omsaravanabhava.org/assets/js/route-status-reconciliation.js", "const RELEASE = 231;"),
+              ("https://omsaravanabhava.org/assets/css/route-status-reconciliation.css", "Release 231"),
+              ("https://omsaravanabhava.org/assets/js/content-status-audit.mjs", "export const RELEASE = 231;"),
+              ("https://omsaravanabhava.org/data/content-status.json", '"mode": "runtime-derived-effective"'),
+              ("https://omsaravanabhava.org/data/publication-boundaries.json", '"release": 231'),
+              ("https://omsaravanabhava.org/manifest-release-231.json", '"release": 231'),
+              ("https://omsaravanabhava.org/service-worker.js", '"/assets/js/route-status-reconciliation.js"'),
+          ]
+
+          results = []
+          for url, marker in checks:
+              passed = False
+              status = None
+              error = ""
+              for _ in range(10):
+                  try:
+                      request = urllib.request.Request(
+                          url,
+                          headers={
+                              "User-Agent": "OmSaravanaBhava-Release-231-Smoke/1.0",
+                              "Cache-Control": "no-cache",
+                          },
+                      )
+                      with urllib.request.urlopen(request, timeout=20) as response:
+                          status = response.status
+                          text = response.read().decode("utf-8", errors="replace")
+                      if status == 200 and marker in text:
+                          passed = True
+                          break
+                      error = f"HTTP {status}; marker absent"
+                  except Exception as exc:
+                      error = str(exc)
+                  time.sleep(15)
+              results.append({
+                  "url": url,
+                  "status": status,
+                  "marker": marker,
+                  "passed": passed,
+                  "error": "" if passed else error,
+              })
+
+          print(json.dumps(results, indent=2, ensure_ascii=False))
+          if any(not item["passed"] for item in results):
+              sys.exit(1)
+          PY
