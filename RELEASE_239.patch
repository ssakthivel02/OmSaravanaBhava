diff --git a/.github/workflows/atomic-publish-verification.yml b/.github/workflows/atomic-publish-verification.yml
new file mode 100644
index 0000000000000000000000000000000000000000..27d75f37ed4d95d888a274ae4e5180ce625ef27a
--- /dev/null
+++ b/.github/workflows/atomic-publish-verification.yml
@@ -0,0 +1,50 @@
+name: Atomic Publish Verification
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: atomic-publish-verification-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  verify:
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check out repository with parent
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 2
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Set up Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+
+      - name: Validate final atomic state
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B -m tools.atomic_publisher.validate             --root .             --mode final
+          python -B -m tools.deployment_conformance.validate --root .
+          python -B -m tools.repository_hygiene.validate --root .
+          python -B -m tools.repository_integrity.validate             --root .             --manifest manifest-release-239.json
+
+      - name: Run regression suites
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          node --test tests/js/*.test.mjs
+          python -B -m unittest discover             -s tests             -p "test_*.py"             -v
