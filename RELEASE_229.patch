@@ -0,0 +1,315 @@
+/*
+Release 229 — Premium Desktop Literature Navigator
+This file extends the existing reading-workspace styles without changing
+mobile-first baseline rules or devotional content presentation.
+*/
+.reading-workspace-help {
+  margin: -4px 0 14px;
+  color: #6a4638;
+  font-size: 0.92rem;
+}
+
+.reading-workspace-help kbd {
+  display: inline-block;
+  min-width: 1.8em;
+  padding: 0.08em 0.42em;
+  border: 1px solid var(--line);
+  border-bottom-width: 2px;
+  border-radius: 0.45em;
+  background: var(--surface-strong, #fff);
+  color: inherit;
+  font: inherit;
+  font-weight: 850;
+  text-align: center;
+}
+
+.reading-workspace-desktop-shell {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr);
+  gap: 18px;
+  align-items: start;
+}
+
+.reading-workspace-panel-heading {
+  display: flex;
+  align-items: flex-start;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 14px;
+}
+
+.reading-workspace-panel-heading h2 {
+  margin: 8px 0 0;
+}
+
+#readingWorkspaceVisibleCount {
+  display: grid;
+  place-items: center;
+  min-width: 3rem;
+  min-height: 3rem;
+  padding: 0.45rem;
+  border: 1px solid var(--line);
+  border-radius: 999px;
+  background: var(--surface-strong, #fff);
+  color: var(--red);
+  font-size: 1.2rem;
+}
+
+.reading-workspace-route-list {
+  display: grid;
+  gap: 10px;
+}
+
+.reading-workspace-route-option {
+  width: 100%;
+  padding: 15px;
+  border: 1px solid var(--line);
+  border-radius: 18px;
+  background: var(--surface-strong, #fff);
+  color: inherit;
+  font: inherit;
+  text-align: left;
+  cursor: pointer;
+}
+
+.reading-workspace-route-option:hover {
+  border-color: var(--orange);
+}
+
+.reading-workspace-route-option:focus-visible {
+  outline: 3px solid currentColor;
+  outline-offset: 3px;
+}
+
+.reading-workspace-route-option[aria-selected="true"] {
+  border-color: var(--red);
+  box-shadow: inset 4px 0 0 var(--red);
+  background: linear-gradient(135deg, rgba(165, 29, 23, 0.06), rgba(244, 156, 44, 0.08));
+}
+
+.reading-workspace-route-option-title {
+  display: block;
+  margin: 8px 0 5px;
+  font-size: 1rem;
+  font-weight: 900;
+  line-height: 1.45;
+}
+
+.reading-workspace-route-option-summary {
+  display: -webkit-box;
+  margin: 0;
+  overflow: hidden;
+  color: #6a4638;
+  font-size: 0.88rem;
+  line-height: 1.55;
+  -webkit-box-orient: vertical;
+  -webkit-line-clamp: 2;
+}
+
+.reading-workspace-route-option-meta,
+.reading-workspace-inspector-labels,
+.reading-workspace-inspector-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  align-items: center;
+}
+
+.reading-workspace-route-option-progress {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 10px;
+  align-items: center;
+  margin-top: 12px;
+}
+
+.reading-workspace-route-option progress,
+.reading-workspace-inspector progress {
+  width: 100%;
+  height: 12px;
+  accent-color: var(--red);
+}
+
+.reading-workspace-route-option-progress span {
+  min-width: 3.2rem;
+  color: var(--red);
+  font-size: 0.82rem;
+  font-weight: 900;
+  text-align: right;
+}
+
+.reading-workspace-inspector {
+  min-width: 0;
+}
+
+.reading-workspace-inspector h2 {
+  margin: 12px 0 6px;
+  overflow-wrap: anywhere;
+}
+
+.reading-workspace-inspector-title-en {
+  margin-top: 0;
+  color: #6a4638;
+  font-weight: 800;
+}
+
+.reading-workspace-inspector-summary {
+  font-size: 1rem;
+  line-height: 1.75;
+}
+
+.reading-workspace-inspector-progress {
+  display: grid;
+  gap: 8px;
+  margin: 18px 0;
+  padding: 16px;
+  border: 1px solid var(--line);
+  border-radius: 18px;
+  background: rgba(244, 156, 44, 0.06);
+}
+
+.reading-workspace-inspector-progress strong {
+  color: var(--red);
+}
+
+.reading-workspace-inspector-facts {
+  display: grid;
+  gap: 0;
+  margin: 18px 0;
+  border: 1px solid var(--line);
+  border-radius: 18px;
+  overflow: hidden;
+}
+
+.reading-workspace-inspector-fact {
+  display: grid;
+  grid-template-columns: minmax(9rem, 0.42fr) minmax(0, 1fr);
+  gap: 14px;
+  padding: 12px 14px;
+  border-bottom: 1px solid var(--line);
+}
+
+.reading-workspace-inspector-fact:last-child {
+  border-bottom: 0;
+}
+
+.reading-workspace-inspector-fact dt {
+  font-weight: 900;
+}
+
+.reading-workspace-inspector-fact dd {
+  margin: 0;
+  overflow-wrap: anywhere;
+}
+
+.reading-workspace-inspector-actions {
+  margin-top: 18px;
+}
+
+.reading-workspace-inspector-actions .btn {
+  min-height: 44px;
+}
+
+.reading-workspace-inspector-boundary {
+  margin-top: 20px;
+  padding: 14px;
+  border-left: 4px solid var(--orange);
+  border-radius: 12px;
+  background: rgba(244, 156, 44, 0.06);
+  font-size: 0.9rem;
+}
+
+.reading-workspace-support-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 18px;
+  margin-top: 18px;
+}
+
+.reading-workspace-support-grid > .card {
+  display: flex;
+  flex-direction: column;
+}
+
+.reading-workspace-support-grid .btn {
+  align-self: flex-start;
+  margin-top: auto;
+}
+
+body.dark .reading-workspace-help,
+body.dark .reading-workspace-route-option-summary,
+body.dark .reading-workspace-inspector-title-en {
+  color: #f4d9c8;
+}
+
+@media (min-width: 1180px) {
+  .reading-workspace-desktop-shell {
+    grid-template-columns: minmax(360px, 0.86fr) minmax(0, 1.34fr);
+    gap: 22px;
+  }
+
+  .reading-workspace-list-panel {
+    position: sticky;
+    top: 18px;
+  }
+
+  .reading-workspace-route-list {
+    max-height: min(68vh, 760px);
+    padding: 2px 8px 4px 2px;
+    overflow: auto;
+    overscroll-behavior: contain;
+    scrollbar-gutter: stable;
+  }
+
+  .reading-workspace-inspector {
+    position: sticky;
+    top: 18px;
+    min-height: 620px;
+  }
+
+  .reading-workspace-support-grid {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 820px) {
+  .reading-workspace-support-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .reading-workspace-inspector-fact {
+    grid-template-columns: 1fr;
+    gap: 4px;
+  }
+
+  .reading-workspace-inspector-actions .btn {
+    width: 100%;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .reading-workspace-route-option {
+    scroll-behavior: auto;
+    transition: none;
+  }
+}
+
+@media print {
+  .reading-workspace-help,
+  .reading-workspace-controls,
+  .reading-workspace-list-panel,
+  #readingWorkspaceStatus {
+    display: none !important;
+  }
+
+  .reading-workspace-desktop-shell,
+  .reading-workspace-support-grid {
+    display: block !important;
+  }
+
+  .reading-workspace-inspector {
+    position: static !important;
+    min-height: 0;
+    break-inside: avoid;
+  }
+}
