+name: Release 229 Production Smoke
+
+on:
+  workflow_dispatch:
+  schedule:
+    - cron: "17 2 * * *"
+  workflow_run:
+    workflows: ["pages-build-deployment"]
+    types: [completed]
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-229-production-smoke
+  cancel-in-progress: true
+
+jobs:
+  smoke:
+    if: >-
+      github.event_name != 'workflow_run' ||
+      github.event.workflow_run.conclusion == 'success'
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check deployed Release 229 assets with retry
+        shell: bash
+        run: |
+          python - <<'PY'
+          import json
+          import sys
+          import time
+          import urllib.request
+
+          checks = [
+              ("https://omsaravanabhava.org/", "ஓம் சரவணபவ"),
+              ("https://omsaravanabhava.org/reading-workspace.html", 'data-release="229"'),
+              ("https://omsaravanabhava.org/assets/css/reading-workspace-desktop.css", "@media (min-width: 1180px)"),
+              ("https://omsaravanabhava.org/assets/js/reading-workspace-desktop.mjs", "export const RELEASE = 229;"),
+              ("https://omsaravanabhava.org/manifest-release-229.json", '"release": 229'),
+              ("https://omsaravanabhava.org/service-worker.js", '"/assets/js/reading-workspace-desktop.mjs"'),
+          ]
+
+          report = []
+          for url, marker in checks:
+              last_error = ""
+              passed = False
+              status = None
+              for attempt in range(10):
+                  try:
+                      request = urllib.request.Request(
+                          url,
+                          headers={
+                              "User-Agent": "OmSaravanaBhava-Release-229-Smoke/1.0",
+                              "Cache-Control": "no-cache",
+                          },
+                      )
+                      with urllib.request.urlopen(request, timeout=20) as response:
+                          status = response.status
+                          text = response.read().decode("utf-8", errors="replace")
+                      if status == 200 and marker in text:
+                          passed = True
+                          break
+                      last_error = f"HTTP {status}; marker absent"
+                  except Exception as exc:
+                      last_error = str(exc)
+                  time.sleep(15)
+              report.append({
+                  "url": url,
+                  "status": status,
+                  "marker": marker,
+                  "passed": passed,
+                  "error": "" if passed else last_error,
+              })
+
+          print(json.dumps(report, indent=2, ensure_ascii=False))
+          failures = [item for item in report if not item["passed"]]
+          if failures:
+              sys.exit(1)
+          PY
diff --git a/assets/css/reading-workspace-desktop.css b/assets/css/reading-workspace-desktop.css
