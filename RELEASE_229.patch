+name: Release 229 Static Site Integrity
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - "reading-workspace.html"
+      - "service-worker.js"
+      - "assets/css/reading-workspace-desktop.css"
+      - "assets/js/reading-workspace-desktop.mjs"
+      - "tests/reading-workspace-desktop.test.mjs"
+      - "tools/release_229_validate.py"
+      - "manifest-release-229.json"
+      - "RELEASE_229_*"
+      - ".github/workflows/release-229-integrity.yml"
+  pull_request:
+    paths:
+      - "reading-workspace.html"
+      - "service-worker.js"
+      - "assets/css/reading-workspace-desktop.css"
+      - "assets/js/reading-workspace-desktop.mjs"
+      - "tests/reading-workspace-desktop.test.mjs"
+      - "tools/release_229_validate.py"
+      - "manifest-release-229.json"
+      - "RELEASE_229_*"
+      - ".github/workflows/release-229-integrity.yml"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-229-integrity-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  validate:
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check out repository
+        uses: actions/checkout@v4
+
+      - name: Set up Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Validate JavaScript syntax
+        run: node --check assets/js/reading-workspace-desktop.mjs
+
+      - name: Run Release 229 Node tests
+        run: node --test tests/reading-workspace-desktop.test.mjs
+
+      - name: Run repository-mode Release 229 validator
+        run: |
+          python tools/release_229_validate.py             --root .             --report artifacts/release-229-repository-validation.json
+
+      - name: Upload validation evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-229-integrity-evidence
+          path: artifacts/release-229-repository-validation.json
+          if-no-files-found: warn
+          retention-days: 30
