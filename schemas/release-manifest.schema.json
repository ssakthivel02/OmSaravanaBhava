{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omsaravanabhava.org/schemas/release-manifest.schema.json",
  "title": "OmSaravanaBhava Release Manifest",
  "type": "object",
  "required": [
    "project",
    "release",
    "base_release",
    "base_commit",
    "required_commit_title",
    "added_files",
    "modified_files",
    "deleted_files",
    "known_limitations"
  ],
  "properties": {
    "project": {
      "const": "OmSaravanaBhava"
    },
    "release": {
      "type": "integer",
      "minimum": 1
    },
    "base_release": {
      "type": "integer",
      "minimum": 0
    },
    "base_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "required_commit_title": {
      "type": "string",
      "minLength": 1
    },
    "added_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "modified_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deleted_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
