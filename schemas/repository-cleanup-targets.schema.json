{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release",
    "trackedPathsToRemove"
  ],
  "properties": {
    "release": {
      "type": "integer",
      "minimum": 1
    },
    "trackedPathsToRemove": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    }
  }
}
