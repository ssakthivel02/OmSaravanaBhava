{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release",
    "repository",
    "branch",
    "baseCommit",
    "commitTitle",
    "mode",
    "browserUploadAllowed",
    "verifyExactStagedCoverage"
  ],
  "properties": {
    "release": {
      "const": 239
    },
    "baseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "mode": {
      "const": "fresh-clone-manifest-transaction"
    },
    "browserUploadAllowed": {
      "const": false
    }
  }
}
