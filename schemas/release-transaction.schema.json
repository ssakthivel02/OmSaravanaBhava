{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release",
    "mode",
    "transactionBaseCommit",
    "bootstrapCommitTitle",
    "finalCommitTitle",
    "stages"
  ],
  "properties": {
    "release": {
      "const": 238
    },
    "mode": {
      "const": "browser-bootstrap-auto-finalizer"
    },
    "transactionBaseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "stages": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2
    }
  }
}
