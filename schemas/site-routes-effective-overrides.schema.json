{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omsaravanabhava.org/schemas/site-routes-effective-overrides.schema.json",
  "title": "Effective route overrides",
  "type": "object",
  "required": [
    "release",
    "sourceRelease",
    "recordCount",
    "records",
    "limitations"
  ],
  "properties": {
    "release": {
      "type": "integer",
      "minimum": 1
    },
    "sourceRelease": {
      "type": "integer",
      "minimum": 1
    },
    "recordCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "status",
          "summary",
          "publicationStatusPrevious",
          "publicationStatusCanonical",
          "publicationStatusSource",
          "publicationBoundaryRelease",
          "readingEligible",
          "fullTextPublished",
          "sourceDataPath",
          "pageRobots",
          "evidenceMarker"
        ]
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
