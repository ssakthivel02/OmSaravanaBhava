{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release",
    "stageCommit",
    "finalCommitTitle",
    "deletedPaths",
    "validation"
  ],
  "properties": {
    "release": {
      "const": 240
    },
    "stageCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "deletedPaths": {
      "type": "array",
      "minItems": 94,
      "maxItems": 94,
      "uniqueItems": true
    }
  }
}
