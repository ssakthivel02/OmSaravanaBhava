{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omsaravanabhava.org/schemas/repository-hygiene-report.schema.json",
  "type": "object",
  "required": [
    "status",
    "scanned_files",
    "violation_count",
    "violations",
    "ignored_allowlist"
  ],
  "properties": {
    "status": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "scanned_files": {
      "type": "integer",
      "minimum": 0
    },
    "violation_count": {
      "type": "integer",
      "minimum": 0
    },
    "violations": {
      "type": "array"
    },
    "ignored_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
