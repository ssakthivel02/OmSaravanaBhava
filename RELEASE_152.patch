+/* Release 152 — persistent verified-text player */
+body.osb-player-active{padding-bottom:clamp(300px,34vh,390px)}
+.read-aloud-queue-card{display:flex;flex-direction:column}
+.read-aloud-queue-card .audio-card-actions{margin-top:auto}
+.osb-media-player{
+  position:fixed;
+  left:18px;
+  right:18px;
+  bottom:18px;
+  z-index:120;
+  display:grid;
+  grid-template-columns:minmax(260px,1.4fr) auto minmax(280px,1fr);
+  gap:20px;
+  align-items:center;
+  max-width:1220px;
+  margin:0 auto;
+  padding:18px 54px 18px 20px;
+  border:1px solid rgba(176,141,87,.34);
+  border-radius:26px;
+  background:rgba(255,250,243,.96);
+  box-shadow:0 30px 90px rgba(65,24,10,.28);
+  backdrop-filter:blur(22px) saturate(150%);
+}
+body.dark .osb-media-player{background:rgba(36,18,12,.96)}
+.osb-media-player[hidden]{display:none!important}
+.player-close{
+  position:absolute;
+  top:10px;
+  right:12px;
+  width:40px;
+  height:40px;
+  border:0;
+  border-radius:50%;
+  background:transparent;
+  color:var(--ink);
+  font-size:1.65rem;
+  cursor:pointer;
+}
+.player-identity{display:flex;gap:14px;align-items:center;min-width:0}
+.player-art{
+  flex:0 0 64px;
+  width:64px;
+  height:64px;
+  display:grid;
+  place-items:center;
+  border-radius:18px;
+  background:linear-gradient(145deg,#74170f,#a94f00);
+  color:#fff;
+  font-family:var(--font-tamil);
+  font-size:1.55rem;
+  font-weight:900;
+}
+.player-identity h2{margin:0;font-size:clamp(1.05rem,.95rem + .4vw,1.35rem);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
+.player-identity p{margin:2px 0;max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
+.player-kicker{font-size:.78rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;color:var(--red)}
+.player-controls{display:flex;gap:10px;align-items:center;justify-content:center}
+.player-control{
+  width:46px;
+  height:46px;
+  border:1px solid var(--line);
+  border-radius:50%;
+  background:var(--surface-strong);
+  color:var(--ink);
+  font:inherit;
+  font-size:1.1rem;
+  cursor:pointer;
+}
+.player-control-primary{width:58px;height:58px;background:var(--red);color:#fff;border-color:var(--red);font-size:1.3rem}
+.player-options{display:grid;grid-template-columns:1fr .7fr;gap:8px 12px;align-items:end}
+.player-options label{font-size:.78rem;font-weight:900}
+.player-options select{display:block;width:100%;min-height:42px;margin-top:3px;border:1px solid var(--line);border-radius:10px;padding:6px 8px;background:var(--surface-strong);color:var(--ink);font:inherit}
+.player-checkbox{display:flex!important;align-items:center;gap:8px;min-height:42px}
+.player-checkbox input{width:18px;height:18px}
+.player-status{grid-column:1/-1;margin:0;min-height:1.5em;font-weight:800;color:var(--red)}
+@media(max-width:980px){
+  body.osb-player-active{padding-bottom:460px}
+  .osb-media-player{grid-template-columns:1fr auto;padding-right:48px}
+  .player-options{grid-column:1/-1;grid-template-columns:1fr 1fr}
+  .player-status{grid-column:1/-1}
+}
+@media(max-width:640px){
+  body.osb-player-active{padding-bottom:590px}
+  .osb-media-player{left:8px;right:8px;bottom:8px;grid-template-columns:1fr;padding:16px 44px 16px 16px;border-radius:22px}
+  .player-controls{justify-content:flex-start}
+  .player-options{grid-column:auto;grid-template-columns:1fr}
+  .player-status{grid-column:auto}
+  .player-art{width:52px;height:52px;flex-basis:52px}
+}
