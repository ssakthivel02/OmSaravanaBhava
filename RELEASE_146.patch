+  }
+
+  if (url.pathname.startsWith('/data/') || request.destination === 'json') {
+    event.respondWith(dataNetworkFirst(request));
+    return;
+  }
+
+  if (['style', 'script', 'image', 'font'].includes(request.destination)) {
+    event.respondWith(staleWhileRevalidate(request));
+    return;
+  }
+
+  event.respondWith(staleWhileRevalidate(request));
+});
+
