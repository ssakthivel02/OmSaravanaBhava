+(()=>{'use strict';document.addEventListener('DOMContentLoaded',async()=>{const root=document.getElementById('privacyPrefs');if(!root)return;const data=await fetch('data/privacy-preferences.json').then(r=>r.json());root.innerHTML=data.map(x=>`<article class="card"><h2>${x.label}</h2><p><code>${x.storage}</code></p><button class="btn secondary" data-clear="${x.storage}">Clear local data</button></article>`).join('');document.addEventListener('click',e=>{const b=e.target.closest('[data-clear]');if(!b)return;localStorage.removeItem(b.dataset.clear);b.textContent='Cleared'})})})();--- before/service-worker.js
