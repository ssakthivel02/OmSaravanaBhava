diff --git a/scripts/repository/preflight-hygiene.ps1 b/scripts/repository/preflight-hygiene.ps1
new file mode 100644
index 0000000000000000000000000000000000000000..51e600ad9f8fcfe95eca91c969eb64e910ab5edf
--- /dev/null
+++ b/scripts/repository/preflight-hygiene.ps1
@@ -0,0 +1,13 @@
+[CmdletBinding()]
+param([string]$Root = ".")
+
+$ErrorActionPreference = "Stop"
+Push-Location $Root
+try {
+    $env:PYTHONDONTWRITEBYTECODE = "1"
+    python -B -m tools.repository_hygiene.validate --root .
+    if ($LASTEXITCODE -ne 0) { throw "Repository hygiene validation failed." }
+}
+finally {
+    Pop-Location
+}
