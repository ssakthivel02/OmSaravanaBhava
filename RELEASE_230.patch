@@ -0,0 +1,82 @@
+name: Release 230 Publication Boundary Integrity
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - "content-status.html"
+      - "service-worker.js"
+      - "data/content-status.json"
+      - "data/reading-workspace.json"
+      - "data/publication-boundaries.json"
+      - "assets/css/content-status-audit.css"
+      - "assets/js/content-status-audit.mjs"
+      - "assets/js/reading-workspace-desktop.mjs"
+      - "tests/publication-boundaries.test.mjs"
+      - "tools/release_230_validate.py"
+      - "manifest-release-230.json"
+      - "RELEASE_230_*"
+      - ".github/workflows/release-230-integrity.yml"
+  pull_request:
+    paths:
+      - "content-status.html"
+      - "service-worker.js"
+      - "data/content-status.json"
+      - "data/reading-workspace.json"
+      - "data/publication-boundaries.json"
+      - "assets/css/content-status-audit.css"
+      - "assets/js/content-status-audit.mjs"
+      - "assets/js/reading-workspace-desktop.mjs"
+      - "tests/publication-boundaries.test.mjs"
+      - "tools/release_230_validate.py"
+      - "manifest-release-230.json"
+      - "RELEASE_230_*"
+      - ".github/workflows/release-230-integrity.yml"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-230-boundary-integrity-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  validate:
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check out repository
+        uses: actions/checkout@v4
+
+      - name: Set up Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Validate browser modules
+        run: |
+          node --check assets/js/content-status-audit.mjs
+          node --check assets/js/reading-workspace-desktop.mjs
+          node --check service-worker.js
+
+      - name: Run publication-boundary tests
+        run: node --test tests/publication-boundaries.test.mjs
+
+      - name: Run repository-mode validator
+        run: |
+          python tools/release_230_validate.py             --root .             --report artifacts/release-230-repository-validation.json
+
+      - name: Upload validation evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-230-publication-boundary-evidence
+          path: artifacts/release-230-repository-validation.json
+          if-no-files-found: warn
+          retention-days: 30
