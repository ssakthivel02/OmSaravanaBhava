diff --git a/.github/workflows/release-238-finalize.yml b/.github/workflows/release-238-finalize.yml
new file mode 100644
index 0000000000000000000000000000000000000000..d9cc1ec849593f18acd0d32b70df2556ca948572
--- /dev/null
+++ b/.github/workflows/release-238-finalize.yml
@@ -0,0 +1,105 @@
+name: Release 238 Finalizer
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - manifest-release-238.json
+      - data/release-238-transaction.json
+      - .github/workflows/release-238-finalize.yml
+  workflow_dispatch:
+
+permissions:
+  contents: write
+
+concurrency:
+  group: release-238-finalizer
+  cancel-in-progress: false
+
+jobs:
+  finalize:
+    if: github.actor != 'github-actions[bot]'
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    steps:
+      - name: Check out bootstrap commit
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+          token: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Set up Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+
+      - name: Verify bootstrap transaction
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B scripts/release238/verify-bootstrap.py --root .
+          python -B -m tools.release_transaction.validate \
+            --root . \
+            --mode bootstrap
+
+      - name: Prepare final repository state
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B scripts/release238/finalize-release-238.py \
+            --root . \
+            --bootstrap-sha "${GITHUB_SHA}"
+          python -B scripts/release238/verify-final-state.py --root .
+
+      - name: Run Release 238 tests
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B scripts/release238/run-release-238-tests.py --root .
+
+      - name: Validate repository gates
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B -m tools.deployment_conformance.validate --root .
+          python -B -m tools.repository_hygiene.validate --root .
+          python -B -m tools.repository_integrity.validate \
+            --root . \
+            --manifest manifest-release-238.json
+          python -B tools/release_validate.py \
+            --root . \
+            --manifest manifest-release-238.json \
+            --package-mode
+          python -B scripts/release238/finalize-release-238.py \
+            --root . \
+            --mark-pass
+
+      - name: Create exact final release commit
+        run: |
+          git config user.name "OmSaravanaBhava Release Bot"
+          git config user.email "actions@users.noreply.github.com"
+          git diff --cached --name-status
+          git commit -m "Release 238: reconcile repository state and enforce deployment conformance"
+
+      - name: Validate final commit
+        env:
+          PYTHONDONTWRITEBYTECODE: "1"
+        run: |
+          python -B tools/release_validate.py \
+            --root . \
+            --manifest manifest-release-238.json \
+            --repository-mode \
+            --strict-commit-subject
+          python -B -m tools.release_transaction.validate \
+            --root . \
+            --mode final \
+            --bootstrap-commit "${GITHUB_SHA}"
+
+      - name: Push final commit
+        run: |
+          git push origin HEAD:main
