+        : '';
+      if (!route || !path || routeSeen.has(path)) return;
+      routeSeen.add(path);
+      routes.push({
+        route,
+        addedAt:
+          normaliseIsoDate(item.addedAt) ||
+          new Date(0).toISOString()
+      });
+    });
+
