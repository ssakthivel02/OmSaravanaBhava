+      const empty = document.createElement('article');
+      empty.className = 'card';
+      createText(empty, 'h3', 'No eligible routes match');
+      createText(empty, 'p',
+        'Try Tamil or English title, category or publication state.');
+      routeHost.appendChild(empty);
