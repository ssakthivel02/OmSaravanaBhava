+(()=>{'use strict';document.addEventListener('DOMContentLoaded',async()=>{const root=document.getElementById('quizRoot');if(!root)return;const q=await fetch('data/learning-quiz.json').then(r=>r.json());root.innerHTML=q.map((x,i)=>`<fieldset class="card"><legend>${i+1}. ${x.question}</legend>${x.options.map((o,j)=>`<label><input type="radio" name="${x.id}" value="${j}"> ${o}</label><br>`).join('')}<button type="button" class="btn secondary" data-check="${x.id}">Check</button><p id="${x.id}-status" role="status"></p></fieldset>`).join('');document.addEventListener('click',e=>{const b=e.target.closest('[data-check]');if(!b)return;const item=q.find(x=>x.id===b.dataset.check);const chosen=document.querySelector(`input[name="${item.id}"]:checked`);document.getElementById(`${item.id}-status`).textContent=!chosen?'Choose an answer.':Number(chosen.value)===item.answer?'Correct.':'Review the linked source page.'})})})();--- before/service-worker.js
