+"""Verify the clean clone is exactly at the approved Release 236 base."""
+
+from __future__ import annotations
+
+import argparse
+import subprocess
+from pathlib import Path
+
+EXPECTED = "dfc5ce53229d9af53a99fe9a089d5d29bb3ea9b5"
+
+
+def main() -> int:
