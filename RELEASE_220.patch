+<!doctype html>
+<html lang="ta">
+<head>
+<meta charset="utf-8">
+<meta name="viewport" content="width=device-width,initial-scale=1">
+<title>Knowledge Graph Explorer | Om Saravana Bhava</title>
+<meta name="description" content="Explore existing local OmSaravanaBhava graph registers, explicit source-page nodes and published relationship counts without inferred theological edges.">
+<meta name="robots" content="index,follow">
+<link rel="canonical" href="https://omsaravanabhava.org/knowledge-graph-explorer.html">
+<link rel="stylesheet" href="assets/css/osb44.css">
+<link rel="stylesheet" href="assets/css/knowledge-graph-explorer.css">
+<link rel="icon" href="favicon.svg" type="image/svg+xml">
+<meta name="theme-color" content="#a51d17">
+<link rel="manifest" href="manifest.json">
+<script defer src="assets/js/pwa-register.js"></script>
+<script type="module" src="assets/js/knowledge-graph-explorer.mjs"></script>
+</head>
+<body data-release="220">
+<a href="#main-content" class="skip-link">Skip to main content</a>
+<div class="top">🛕 ஓம் சரவணபவ · Source-controlled local graph explorer</div>
