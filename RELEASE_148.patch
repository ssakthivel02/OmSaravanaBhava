+
+  document.querySelectorAll('[data-filter]').forEach(button => {
+    button.type = 'button';
+    button.setAttribute('aria-pressed', button.dataset.filter === 'All' ? 'true' : 'false');
+    button.addEventListener('click', () => {
+      const selected = button.dataset.filter;
