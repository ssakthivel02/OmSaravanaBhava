{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release",
    "baseCommit",
    "requiredCommitTitle",
    "serviceWorkerRelease",
    "approvedWorkflows",
    "requiredPermanentControls",
    "forbiddenExactPaths"
  ],
  "properties": {
    "release": {
      "const": 241
    },
    "baseCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "serviceWorkerRelease": {
      "const": "241"
    },
    "maximumChangedPaths": {
      "type": "integer",
      "maximum": 500
    }
  }
}
