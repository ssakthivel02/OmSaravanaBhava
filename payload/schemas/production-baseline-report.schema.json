{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "release",
    "findingCount",
    "findings"
  ],
  "properties": {
    "status": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "release": {
      "const": 243
    },
    "findingCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
