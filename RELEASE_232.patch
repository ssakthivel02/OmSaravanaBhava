@@ -0,0 +1,65 @@
+name: Release 232 Independent Attestation
+
+on:
+  workflow_dispatch:
+  schedule:
+    - cron: "17 3 * * *"
+  workflow_run:
+    workflows: ["Release 232 Deterministic Governance Gate"]
+    types: [completed]
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-232-independent-attestation
+  cancel-in-progress: true
+
+jobs:
+  attest:
+    if: >-
+      github.event_name != 'workflow_run' ||
+      github.event.workflow_run.conclusion == 'success'
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Resolve commit
+        id: resolve
+        shell: bash
+        run: |
+          if [ "${{ github.event_name }}" = "workflow_run" ]; then
+            echo "sha=${{ github.event.workflow_run.head_sha }}" >> "$GITHUB_OUTPUT"
+          else
+            echo "sha=${{ github.sha }}" >> "$GITHUB_OUTPUT"
+          fi
+
+      - name: Check out attested commit
+        uses: actions/checkout@v4
+        with:
+          ref: ${{ steps.resolve.outputs.sha }}
+          fetch-depth: 2
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Discover latest numeric release manifest
+        id: manifest
+        shell: bash
+        run: |
+          manifest="$(python -m tools.release_control.discovery --root .)"
+          echo "path=$manifest" >> "$GITHUB_OUTPUT"
+          echo "Using $manifest"
+
+      - name: Re-run deterministic governance
+        run: |
+          python tools/release_232_validate.py             --root .             --manifest "${{ steps.manifest.outputs.path }}"             --repository-mode             --report artifacts/release-232-independent-report.json             --attestation artifacts/release-232-independent-attestation.json
+
+      - name: Upload independent attestation
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-232-independent-attestation
+          path: artifacts/
+          if-no-files-found: error
+          retention-days: 90
diff --git a/.github/workflows/release-232-governance.yml b/.github/workflows/release-232-governance.yml
new file mode 100644
index 0000000000000000000000000000000000000000..d4986a54d1b65fa1a964f6f3a4ea83bd0c154880
--- /dev/null
+++ b/.github/workflows/release-232-governance.yml
@@ -0,0 +1,95 @@
+name: Release 232 Deterministic Governance Gate
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-232-governance-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  governance:
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    steps:
+      - name: Check out repository with parent commit
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 2
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Discover latest numeric release manifest
+        id: manifest
+        shell: bash
+        run: |
+          manifest="$(python -m tools.release_control.discovery --root .)"
+          echo "path=$manifest" >> "$GITHUB_OUTPUT"
+          echo "Using $manifest"
+
+      - name: Compile release governance tools
+        run: |
+          python -m compileall -q tools/release_control tools/release_232_validate.py
+
+      - name: Run governance unit tests
+        run: |
+          python -m unittest discover \
+            -s tests/release_control \
+            -p "test_*.py" \
+            -v
+
+      - name: Validate uploaded commit and generate attestation
+        run: |
+          python tools/release_232_validate.py \
+            --root . \
+            --manifest "${{ steps.manifest.outputs.path }}" \
+            --repository-mode \
+            --report artifacts/release-232-governance-report.json \
+            --attestation artifacts/release-232-attestation.json
+
+      - name: Write job summary
+        if: always()
+        shell: bash
+        run: |
+          echo "# Release 232 governance" >> "$GITHUB_STEP_SUMMARY"
+          echo >> "$GITHUB_STEP_SUMMARY"
+          if [ ! -f artifacts/release-232-governance-report.json ]; then
+            echo "Report was not generated." >> "$GITHUB_STEP_SUMMARY"
+            exit 0
+          fi
+          python - <<'PY' >> "$GITHUB_STEP_SUMMARY"
+          import json
+          from pathlib import Path
+
+          payload = json.loads(
+              Path("artifacts/release-232-governance-report.json")
+              .read_text(encoding="utf-8")
+          )
+          print(f"**Status:** {payload['status']}")
+          print()
+          print("| Check | Status | Result |")
+          print("|---|---:|---|")
+          for check in payload.get("checks", []):
+              message = str(check.get("message", "")).replace("|", "\\|")
+              print(
+                  f"| {check.get('name')} | {check.get('status')} | {message} |"
+              )
+          PY
+
+      - name: Upload governance evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-232-governance-evidence
+          path: artifacts/
+          if-no-files-found: warn
+          retention-days: 90
