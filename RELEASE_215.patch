+name: Release 215 Static Site Integrity
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  integrity:
+    name: Release 215 repository validation
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Set up Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: "20"
+
+      - name: Validate Release 215 identities and routes
+        run: python tools/release_215_validate.py --root . --report artifacts/release-215-overlay-validation.json
+
+      - name: Check search facets JavaScript syntax
+        run: node --check assets/js/search-facets.mjs
+
+      - name: Run search facets unit tests
+        run: node --test tests/search-facets.test.mjs
+
+      - name: Run site-audit unit tests
+        run: python -m unittest discover -s tests -p 'test_site_audit.py'
+
+      - name: Run repository-wide static audit
+        run: python tools/site_audit.py --root . --json-report artifacts/release-215-site-audit.json --markdown-report artifacts/release-215-site-audit.md
+
+      - name: Upload Release 215 integrity evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-215-static-integrity-${{ github.sha }}
+          path: artifacts/
+          if-no-files-found: error
