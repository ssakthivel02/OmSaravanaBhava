@@ -0,0 +1,43 @@
+name: Release 215 Production Smoke
+
+on:
+  push:
+    branches: [main]
+  workflow_dispatch:
+  schedule:
+    - cron: "17 3 * * *"
+
+permissions:
+  contents: read
+
+concurrency:
+  group: release-215-production-smoke
+  cancel-in-progress: true
+
+jobs:
+  smoke:
+    name: Observe deployed Release 215
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+
+      - name: Allow GitHub Pages deployment to begin
+        if: github.event_name == 'push'
+        run: sleep 90
+
+      - name: Run deployed production smoke checks
+        run: python tools/production_smoke.py --retries 18 --delay 20 --report artifacts/release-215-production-smoke.json
+
+      - name: Upload Release 215 production evidence
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: release-215-production-smoke-${{ github.sha }}
+          path: artifacts/release-215-production-smoke.json
+          if-no-files-found: error
